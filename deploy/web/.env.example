# =============================================================================
# Web Instance .env — EXAMPLE (copy to .env and fill in real values)
# =============================================================================
# This file is committed to the repo as a reference.
# The actual .env file with real passwords is NEVER committed.
#
# NOTE: RUN_MIGRATIONS=1 on the OD instance ONLY.
#       Spot instances use RUN_MIGRATIONS=0 (or omit it).
# =============================================================================

# Django core
DJANGO_SECRET_KEY=CHANGE_ME
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=http://CHANGE_ME_ELASTIC_IP
ENVIRONMENT=production

# PostgreSQL — on the DB box (use private VPC IP for low latency)
DB_HOST=CHANGE_ME_DB_PRIVATE_IP
DB_PORT=5432
DB_NAME=createscale
DB_USER=createscale
DB_PASSWORD=CHANGE_ME

# Redis — on the DB box
REDIS_URL=redis://CHANGE_ME_DB_PRIVATE_IP:6379/1

# R2/S3 media storage
# For R2: set explicit keys (no IAM Instance Profile for Cloudflare)
AWS_ACCESS_KEY_ID=CHANGE_ME_R2_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=CHANGE_ME_R2_SECRET_KEY
USE_S3=1
AWS_STORAGE_BUCKET_NAME=artkhoj-media
AWS_S3_REGION_NAME=auto
AWS_S3_ENDPOINT_URL=https://CHANGE_ME_CF_ACCOUNT_ID.r2.cloudflarestorage.com
# AWS_S3_CUSTOM_DOMAIN=media.CHANGE_ME_DOMAIN.com  # Enable in Phase 3

# HTTPS (set to "https" when behind Cloudflare SSL)
# ACCOUNT_HTTP_PROTOCOL=https  # Enable in Phase 4

# Google OAuth
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

# Twitter OAuth 2.0
TWITTER_CLIENT_ID=CHANGE_ME
TWITTER_CLIENT_SECRET=CHANGE_ME

# LinkedIn OAuth 2.0
LINKEDIN_CLIENT_ID=CHANGE_ME
LINKEDIN_CLIENT_SECRET=CHANGE_ME

# GlitchTip (error tracking) — on the DB box
SENTRY_DSN=http://CHANGE_ME_DSN_KEY@CHANGE_ME_DB_PRIVATE_IP:8000/1

# Migration control: 1 on OD instance, 0 on Spot instances
RUN_MIGRATIONS=1

# Gunicorn (optimal for 2-core c7g.large)
WEB_CONCURRENCY=3
WEB_THREADS=2
WEB_TIMEOUT=30
