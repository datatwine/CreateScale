# =============================================================================
# Unified .env — EXAMPLE (all boxes pull from s3://createscale-config/.env)
# =============================================================================
# This file is committed to the repo as a reference.
# The actual .env file with real values lives ONLY on S3 (never committed).
#
# All boxes (Web OD, Web Spot, DB) share the same .env. Each service reads
# only the vars it needs and ignores the rest.
#
# DEPLOY PIPELINE OVERRIDES (via sed on OD only):
#   RUN_MIGRATIONS=0 → 1   (OD runs migrations, Spot does not)
#   RUN_BEAT=0 → 1         (OD runs Celery beat, Spot does not)
# =============================================================================

# ── Django core ──────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=CHANGE_ME
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=http://CHANGE_ME_ELASTIC_IP
ENVIRONMENT=production
ACCOUNT_HTTP_PROTOCOL=https

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Web instances connect through PgBouncer on the DB box (port 6432).
# DB box services use the docker-compose service name "db" internally.
DB_HOST=CHANGE_ME_DB_PRIVATE_IP
DB_PORT=6432
DB_NAME=createscale
DB_USER=createscale
DB_PASSWORD=CHANGE_ME

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://CHANGE_ME_DB_PRIVATE_IP:6379/1

# ── R2/S3 media storage ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=CHANGE_ME_R2_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=CHANGE_ME_R2_SECRET_KEY
USE_S3=1
AWS_STORAGE_BUCKET_NAME=artkhoj-media
AWS_S3_REGION_NAME=auto
AWS_S3_ENDPOINT_URL=https://CHANGE_ME_CF_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_S3_CUSTOM_DOMAIN=media.CHANGE_ME_DOMAIN.com

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_IOS_CLIENT_ID=CHANGE_ME

# ── Twitter OAuth 2.0 ───────────────────────────────────────────────────────
TWITTER_CLIENT_ID=CHANGE_ME
TWITTER_CLIENT_SECRET=CHANGE_ME
X_CLIENT_ID=CHANGE_ME
X_SECRET_KEY=CHANGE_ME

# ── LinkedIn OAuth 2.0 ──────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=CHANGE_ME
LINKEDIN_CLIENT_SECRET=CHANGE_ME
LINKED_IN_CLIENT_ID=CHANGE_ME
LINKED_IN_CLIENT_SECRET=CHANGE_ME

# ── Razorpay (linked account payments) ──────────────────────────────────────
RAZORPAY_KEY_ID=CHANGE_ME
RAZORPAY_KEY_SECRET=CHANGE_ME
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME
# RAZORPAY_PLATFORM_FEE_PERCENT=5       # default: 5%
# RAZORPAY_PAYMENT_WINDOW_HOURS=24      # default: 24h
# RAZORPAY_DISPUTE_WINDOW_HOURS=24      # default: 24h

# ── GlitchTip (error tracking — on DB box) ──────────────────────────────────
SENTRY_DSN=http://CHANGE_ME_DSN_KEY@CHANGE_ME_DB_PRIVATE_IP:8000/1
GLITCHTIP_SECRET_KEY=CHANGE_ME_64_CHARS
DB_HOST_PUBLIC_IP=CHANGE_ME

# ── Grafana (on DB box — defaults to admin/admin if omitted) ────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME

# ── Deploy pipeline controls ────────────────────────────────────────────────
# Base values. The CI/CD pipeline flips these to 1 on the OD instance only.
RUN_MIGRATIONS=0
RUN_BEAT=0

# ── Gunicorn (optimal for 2-core c7g.large) ────────────────────────────────
WEB_CONCURRENCY=3
WEB_THREADS=2
WEB_TIMEOUT=30
