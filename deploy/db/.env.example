# =============================================================================
# DB Box .env — EXAMPLE (copy to .env and fill in real values)
# =============================================================================
# This file is committed to the repo as a reference.
# The actual .env file with real passwords is NEVER committed.
# =============================================================================

# PostgreSQL — must match the values from your original t3.large setup
DB_NAME=createscale
DB_USER=createscale
DB_PASSWORD=CHANGE_ME

# GlitchTip session encryption — any random 64-char string
GLITCHTIP_SECRET_KEY=CHANGE_ME_64_CHARS

# The DB box's public IP (for GlitchTip's GLITCHTIP_DOMAIN)
DB_HOST_PUBLIC_IP=CHANGE_ME

# Grafana credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME
